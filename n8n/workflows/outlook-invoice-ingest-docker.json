      "id": "a1000001-0001-4000-8000-000000000004",
      "name": "Log No Attachments",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [720, 480]
    },
    {
      "parameters": {
        "jsCode": "// Split Outlook attachment binaries into one item per supported file.\nconst email = $('Outlook New Email').first().json;\nconst binaries = $input.first().binary || {};\nconst supported = new Set(['pdf', 'png', 'jpg', 'jpeg']);\nconst out = [];\n\nfor (const [key, bin] of Object.entries(binaries)) {\n  const name = bin.fileName || bin.fileName || key;\n  const ext = (String(name).split('.').pop() || '').toLowerCase();\n  if (!supported.has(ext)) {\n    out.push({\n      json: {\n        event: 'unsupported_file',\n        attachment_filename: name,\n        message_id: email.id,\n        skip_upload: true,\n      },\n    });\n    continue;\n  }\n  out.push({\n    json: {\n      event: 'attachment_processed',\n      sender_email: email.from?.emailAddress?.address ?? email.sender?.emailAddress?.address,\n      sender_name: email.from?.emailAddress?.name ?? email.sender?.emailAddress?.name,\n      email_subject: email.subject,\n      received_datetime: email.receivedDateTime,\n      message_id: email.id,\n      attachment_filename: name,\n      source: 'outlook_email',\n      skip_upload: false,\n    },\n    binary: { data: bin },\n  });\n}\n\nif (out.length === 0) {\n  return [{ json: { event: 'email_received', note: 'No supported attachments', message_id: email.id, skip_upload: true } }];\n}\nreturn out;"
      },
      "id": "a1000001-0001-4000-8000-000000000005",
      "name": "Split Attachments",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 200]
    },
