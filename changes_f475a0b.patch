+def build_matching_cache(
+    invoices: list[MatchingInvoiceRow],
+    existing_pairs: set[tuple[int, int]],
+    open_bank_tasks: list[tuple[int, str, str | None]],
+) -> MatchingRunCache:
+    by_normalized: dict[str, list[MatchingInvoiceRow]] = {}
+    by_id: dict[int, MatchingInvoiceRow] = {}
+    unpaid: list[MatchingInvoiceRow] = []
+
+    for row in invoices:
+        by_id[row.id] = row
+        if row.paid_at_date is None and row.amount is not None and row.amount > 0:
+            unpaid.append(row)
+        key = row.invoice_number_normalized
+        if key:
+            by_normalized.setdefault(key, []).append(row)
+
+    for key in by_normalized:
+        by_normalized[key].sort(key=lambda r: r.id)
+
+    open_any: set[tuple[int, str]] = set()
+    open_by_number: set[tuple[int, str, str]] = set()
+    for txn_id, reason, payload_number in open_bank_tasks:
+        open_any.add((txn_id, reason))
+        if payload_number:
+            open_by_number.add((txn_id, reason, payload_number))
+
+    return MatchingRunCache(
+        invoices_by_normalized=by_normalized,
+        invoices_by_id=by_id,
+        existing_pairs=set(existing_pairs),
+        open_bank_any=open_any,
+        open_bank_by_number=open_by_number,
+        unpaid_for_batch=unpaid,
+    )
