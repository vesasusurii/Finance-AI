diff --git a/backend/utils/matching_fingerprint.py b/backend/utils/matching_fingerprint.py
new file mode 100644
index 0000000..5a71604
--- /dev/null
+++ b/backend/utils/matching_fingerprint.py
@@ -0,0 +1,132 @@
+"""Fingerprints for skipping unchanged rows on reconciliation re-runs."""
+
+from __future__ import annotations
+
+import hashlib
+import json
+from datetime import datetime
+from typing import TYPE_CHECKING
+
+from utils.bank_comment_hash import bank_comment_hash, normalize_bank_comment
+from utils.batch_payment_matching import REASON_BATCH_AMOUNT_SUGGESTED, no_candidates_reason
+from utils.normalization import normalize_invoice_number
+
+if TYPE_CHECKING:
+    from models.bank_transaction import BankTransaction
+    from services.matching_cache import MatchingRunCache
+
+
+def catalog_fingerprint(
+    invoice_count: int,
+    max_invoice_id: int,
+    max_updated_at: datetime | None,
+) -> str:
+    updated = max_updated_at.isoformat() if max_updated_at else ""
+    return f"{invoice_count}:{max_invoice_id}:{updated}"
+
+
+def candidate_keys_from_lists(
+    regex_only: list[str], from_llm: list[str]
+) -> list[str]:
+    keys: list[str] = []
+    for raw in list(regex_only) + list(from_llm):
+        key = normalize_invoice_number(raw) or raw
+        if key and key not in keys:
+            keys.append(key)
+    return keys
+
+
+def matching_input_fingerprint(
+    *,
+    comment: str | None,
+    candidate_keys: list[str],
+    reconciliation_status: str,
+    catalog_fp: str,
+) -> str:
+    payload = {
+        "comment_hash": bank_comment_hash(comment),
+        "candidate_keys": sorted(candidate_keys),
+        "status": reconciliation_status,
+        "catalog": catalog_fp,
+    }
+    raw = json.dumps(payload, sort_keys=True, separators=(",", ":"))
+    return hashlib.sha256(raw.encode("utf-8")).hexdigest()
+
+
+def stored_detected_keys(txn: BankTransaction) -> list[str]:
+    numbers = txn.detected_invoice_numbers
+    if not isinstance(numbers, list):
+        return []
+    keys: list[str] = []
+    for raw in numbers:
+        key = normalize_invoice_number(str(raw)) or str(raw)
+        if key and key not in keys:
+            keys.append(key)
+    return keys
+
+
+def txn_has_pending_matching_work(
+    txn: BankTransaction,
+    candidate_keys: list[str],
+    cache: MatchingRunCache,
+) -> bool:
+    """True when another matching pass could create matches or review tasks."""
+    if not candidate_keys:
+        reason = no_candidates_reason(txn.comment)
+        if not cache.has_open_bank_task(txn.id, reason):
+            return True
+        if cache.has_open_bank_task(txn.id, REASON_BATCH_AMOUNT_SUGGESTED):
+            return False
+        return txn.transaction_date is not None
+
+    if not txn.transaction_date:
+        return not cache.has_open_bank_task(txn.id, "missing_transaction_date")
+
+    for key in candidate_keys:
+        invoice, ambiguous = cache.find_by_number(key)
+        if ambiguous:
+            if not cache.has_open_bank_task(
+                txn.id, "duplicate_invoice_in_db", invoice_number=key
+            ):
+                return True
+            continue
+        if invoice is not None:
+            if not cache.pair_exists(invoice.id, txn.id):
+                return True
+            continue
+        if not cache.has_open_bank_task(
+            txn.id, "no_invoice_in_db", invoice_number=key
+        ):
+            return True
+
+    return False
+
+
+def should_skip_matching_txn(
+    txn: BankTransaction,
+    *,
+    candidate_keys: list[str],
+    catalog_fp: str,
+    cache: MatchingRunCache,
+) -> bool:
+    """Skip re-processing when inputs are unchanged and no work remains."""
+    if txn.reconciliation_status == "pending":
+        return False
+
+    current_fp = matching_input_fingerprint(
+        comment=txn.comment,
+        candidate_keys=candidate_keys,
+        reconciliation_status=txn.reconciliation_status,
+        catalog_fp=catalog_fp,
+    )
+    stored_fp = getattr(txn, "last_matching_fingerprint", None)
+    if not stored_fp or stored_fp != current_fp:
+        return False
+
+    if stored_detected_keys(txn) != candidate_keys:
+        return False
+
+    if txn_has_pending_matching_work(txn, candidate_keys, cache):
+        return False
+
+    return True
diff --git a/backend/utils/matching_timing.py b/backend/utils/matching_timing.py
new file mode 100644
index 0000000..2be3a33
--- /dev/null
+++ b/backend/utils/matching_timing.py
@@ -0,0 +1,92 @@
+"""INFO-level timing breakdown for reconciliation matching runs."""
+
+from __future__ import annotations
+
+import logging
+import time
+from contextlib import contextmanager
+
+
+class TxnStepProfiler:
+    """Per-transaction sub-step timings (Tier D)."""
+
+    LOG_STEP_MS = 50.0
+
+    def __init__(self) -> None:
+        self._steps: list[tuple[str, float]] = []
+
+    @contextmanager
+    def step(self, name: str):
+        t0 = time.perf_counter()
+        try:
+            yield
+        finally:
+            self._steps.append((name, (time.perf_counter() - t0) * 1000))
+
+    def format_detail(self, base: str) -> str:
+        if not self._steps:
+            return base
+        parts = [f"{name}={ms:.0f}ms" for name, ms in self._steps]
+        return f"{base} | {' '.join(parts)}"
+
+
+class MatchingRunProfiler:
+    """Collect phase timings and emit one summary block at the end."""
+
+    SLOW_TXN_MS = 200.0
+
+    def __init__(
+        self,
+        logger: logging.Logger,
+        *,
+        bank_statement_id: int | None = None,
+    ) -> None:
+        self._logger = logger
+        self._bank_statement_id = bank_statement_id
+        self._run_start = time.perf_counter()
+        self._phases: list[tuple[str, float]] = []
+        self._slow_txns: list[tuple[int, float, str]] = []
+
+    @contextmanager
+    def phase(self, name: str):
+        t0 = time.perf_counter()
+        try:
+            yield
+        finally:
+            self._phases.append((name, (time.perf_counter() - t0) * 1000))
+
+    def record_elapsed(self, name: str, elapsed_ms: float) -> None:
+        """Record a sub-step duration (e.g. individual LLM batch)."""
+        self._phases.append((name, elapsed_ms))
+
+    def record_txn(self, txn_id: int, elapsed_ms: float, detail: str = "") -> None:
+        if elapsed_ms >= self.SLOW_TXN_MS:
+            self._slow_txns.append((txn_id, elapsed_ms, detail))
+
+    def finish(self, *, transaction_count: int) -> None:
+        total_ms = (time.perf_counter() - self._run_start) * 1000
+        scope = (
+            f"bank_statement_id={self._bank_statement_id}"
+            if self._bank_statement_id is not None
+            else "bank_statement_id=all"
+        )
+        self._logger.info(
+            "Matching timing [%s] transactions=%d total=%.1f ms",
+            scope,
+            transaction_count,
+            total_ms,
+        )
+        for name, ms in self._phases:
+            pct = (ms / total_ms * 100.0) if total_ms > 0 else 0.0
+            self._logger.info("  %-32s %9.1f ms (%5.1f%%)", name, ms, pct)
+
+        if self._slow_txns:
+            self._slow_txns.sort(key=lambda item: item[1], reverse=True)
+            self._logger.info(
+                "  slow transactions (>%.0f ms), top %d:",
+                self.SLOW_TXN_MS,
+                min(15, len(self._slow_txns)),
+            )
+            for txn_id, ms, detail in self._slow_txns[:15]:
+                suffix = f" — {detail}" if detail else ""
+                self._logger.info("    txn %-8d %9.1f ms%s", txn_id, ms, suffix)
