new file mode 100644
index 0000000..47d8414
--- /dev/null
+++ b/backend/services/matching_cache.py
@@ -0,0 +1,154 @@
+"""In-memory indexes for a single reconciliation matching run."""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import date
+from decimal import Decimal
+
+
+@dataclass(frozen=True, slots=True)
+class MatchingInvoiceRow:
+    id: int
+    invoice_number: str | None
+    invoice_number_normalized: str | None
+    paid_at_date: date | None
+    match_status: str
+    name_of_company: str | None
+    amount: Decimal | None
+    invoice_date: date | None
+
+
+@dataclass
+class MatchingRunCache:
+    """Prefetched invoice, match, and review-task data for one matching run."""
+
+    invoices_by_normalized: dict[str, list[MatchingInvoiceRow]]
+    invoices_by_id: dict[int, MatchingInvoiceRow]
+    existing_pairs: set[tuple[int, int]]
+    open_bank_any: set[tuple[int, str]]
+    open_bank_by_number: set[tuple[int, str, str]]
+    unpaid_for_batch: list[MatchingInvoiceRow]
+
+    def find_by_number(
+        self, normalized: str
+    ) -> tuple[MatchingInvoiceRow | None, bool]:
+        rows = self.invoices_by_normalized.get(normalized, [])
+        if not rows:
+            return None, False
+        if len(rows) == 1:
+            return rows[0], False
+        return None, True
+
+    def list_by_number(self, normalized: str) -> list[MatchingInvoiceRow]:
+        return list(self.invoices_by_normalized.get(normalized, []))
+
+    def get_by_id(self, invoice_id: int) -> MatchingInvoiceRow | None:
+        return self.invoices_by_id.get(invoice_id)
+
+    def pair_exists(self, invoice_id: int, bank_transaction_id: int) -> bool:
+        return (invoice_id, bank_transaction_id) in self.existing_pairs
+
+    def register_pair(self, invoice_id: int, bank_transaction_id: int) -> None:
+        self.existing_pairs.add((invoice_id, bank_transaction_id))
+
+    def has_open_bank_task(
+        self,
+        bank_transaction_id: int,
+        reason: str,
+        invoice_number: str | None = None,
+    ) -> bool:
+        if not invoice_number:
+            return (bank_transaction_id, reason) in self.open_bank_any
+        return (
+            bank_transaction_id,
+            reason,
+            invoice_number,
+        ) in self.open_bank_by_number
+
+    def register_open_bank_task(
+        self,
+        bank_transaction_id: int,
+        reason: str,
+        invoice_number: str = "",
+    ) -> None:
+        self.open_bank_any.add((bank_transaction_id, reason))
+        if invoice_number:
+            self.open_bank_by_number.add(
+                (bank_transaction_id, reason, invoice_number)
+            )
+
+    def mark_invoice_paid(self, invoice_id: int, paid_date: date) -> None:
+        row = self.invoices_by_id.get(invoice_id)
+        if row is None:
+            return
+        self.invoices_by_id[invoice_id] = MatchingInvoiceRow(
+            id=row.id,
+            invoice_number=row.invoice_number,
+            invoice_number_normalized=row.invoice_number_normalized,
+            paid_at_date=paid_date,
+            match_status="matched",
+            name_of_company=row.name_of_company,
+            amount=row.amount,
+            invoice_date=row.invoice_date,
+        )
+        key = row.invoice_number_normalized
+        if key and key in self.invoices_by_normalized:
+            self.invoices_by_normalized[key] = [
+                self.invoices_by_id[r.id]
+                for r in self.invoices_by_normalized[key]
+            ]
+        self.unpaid_for_batch = [
+            r for r in self.unpaid_for_batch if r.id != invoice_id
+        ]
+
+    def unpaid_in_date_window(
+        self,
+        *,
+        invoice_date_from: date,
+        invoice_date_to: date,
+    ) -> list[MatchingInvoiceRow]:
+        out: list[MatchingInvoiceRow] = []
+        for row in self.unpaid_for_batch:
+            if row.invoice_date is None:
+                continue
+            if invoice_date_from <= row.invoice_date <= invoice_date_to:
+                out.append(row)
+        return out
+
