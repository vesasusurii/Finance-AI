diff --git a/backend/repositories/bank_comment_llm_cache_repository.py b/backend/repositories/bank_comment_llm_cache_repository.py
new file mode 100644
index 0000000..f8b9840
--- /dev/null
+++ b/backend/repositories/bank_comment_llm_cache_repository.py
@@ -0,0 +1,70 @@
+from __future__ import annotations
+
+from datetime import datetime, timezone
+
+from sqlalchemy import select
+from sqlalchemy.dialects.postgresql import insert
+from sqlalchemy.ext.asyncio import AsyncSession
+
+from models.bank_comment_llm_extraction import BankCommentLlmExtraction
+
+
+class BankCommentLlmCacheRepository:
+    def __init__(self, session: AsyncSession) -> None:
+        self._session = session
+
+    async def get_by_hashes(
+        self, comment_hashes: list[str], *, model: str, cache_version: int
+    ) -> dict[str, list[str]]:
+        if not comment_hashes:
+            return {}
+        q = select(
+            BankCommentLlmExtraction.comment_hash,
+            BankCommentLlmExtraction.invoice_numbers,
+        ).where(
+            BankCommentLlmExtraction.comment_hash.in_(comment_hashes),
+            BankCommentLlmExtraction.model == model,
+            BankCommentLlmExtraction.cache_version == cache_version,
+        )
+        rows = (await self._session.execute(q)).all()
+        out: dict[str, list[str]] = {}
+        for comment_hash, numbers in rows:
+            if isinstance(numbers, list):
+                out[str(comment_hash)] = [str(n) for n in numbers]
+            else:
+                out[str(comment_hash)] = []
+        return out
+
+    async def upsert_many(
+        self,
+        entries: list[tuple[str, list[str]]],
+        *,
+        model: str,
+        cache_version: int,
+    ) -> None:
+        if not entries:
+            return
