@@ -0,0 +1,110 @@
+"""Tests for matching skip fingerprints and comment hashing."""
+
+from datetime import date, datetime, timezone
+from decimal import Decimal
+from types import SimpleNamespace
+from unittest.mock import MagicMock
+
+from services.matching_cache import MatchingInvoiceRow, MatchingRunCache
+from utils.bank_comment_hash import bank_comment_hash
+from utils.matching_fingerprint import (
+    candidate_keys_from_lists,
+    catalog_fingerprint,
+    matching_input_fingerprint,
+    should_skip_matching_txn,
+)
+
+
+def _txn(
+    *,
+    status: str = "needs_review",
+    comment: str = "Inv 123",
+    detected: list[str] | None = None,
+    fingerprint: str | None = None,
+    txn_id: int = 1,
+):
+    return SimpleNamespace(
+        id=txn_id,
+        comment=comment,
+        reconciliation_status=status,
+        detected_invoice_numbers=detected or ["123"],
+        last_matching_fingerprint=fingerprint,
+        transaction_date=date(2026, 1, 15),
+    )
+
+
+def _empty_cache() -> MatchingRunCache:
+    return MatchingRunCache(
+        invoices_by_normalized={},
+        invoices_by_id={},
+        existing_pairs=set(),
+        open_bank_any={(1, "no_invoice_in_db")},
+        open_bank_by_number={(1, "no_invoice_in_db", "123")},
+        unpaid_for_batch=[],
+    )
+
+
+def test_bank_comment_hash_stable():
+    assert bank_comment_hash("  Inv 123  ") == bank_comment_hash("Inv 123")
+
+
+def test_should_skip_when_fingerprint_and_tasks_unchanged():
+    catalog = catalog_fingerprint(5, 99, datetime(2026, 1, 1, tzinfo=timezone.utc))
+    keys = candidate_keys_from_lists(["123"], [])
+    fp = matching_input_fingerprint(
+        comment="Inv 123",
+        candidate_keys=keys,
+        reconciliation_status="needs_review",
+        catalog_fp=catalog,
+    )
+    txn = _txn(
+        status="needs_review",
+        detected=["123"],
+        fingerprint=fp,
+    )
+    cache = _empty_cache()
+    assert should_skip_matching_txn(
+        txn, candidate_keys=keys, catalog_fp=catalog, cache=cache
+    )
+
+
+def test_should_not_skip_pending():
+    catalog = catalog_fingerprint(0, 0, None)
+    keys: list[str] = []
+    txn = _txn(status="pending", detected=[], fingerprint=None)
+    assert not should_skip_matching_txn(
+        txn, candidate_keys=keys, catalog_fp=catalog, cache=MagicMock()
+    )
+
+
+def test_should_not_skip_when_new_invoice_could_match():
+    catalog = catalog_fingerprint(1, 1, None)
+    keys = candidate_keys_from_lists(["123"], [])
+    fp = matching_input_fingerprint(
+        comment="Inv 123",
+        candidate_keys=keys,
+        reconciliation_status="needs_review",
+        catalog_fp=catalog,
+    )
+    txn = _txn(detected=["123"], fingerprint=fp)
+    row = MatchingInvoiceRow(
+        id=10,
+        invoice_number="123",
+        invoice_number_normalized="123",
+        paid_at_date=None,
+        match_status="unmatched",
+        name_of_company="ACME",
+        amount=Decimal("10"),
+        invoice_date=date(2026, 1, 1),
+    )
+    cache = MatchingRunCache(
+        invoices_by_normalized={"123": [row]},
+        invoices_by_id={10: row},
+        existing_pairs=set(),
+        open_bank_any=set(),
+        open_bank_by_number=set(),
+        unpaid_for_batch=[row],
+    )
+    assert not should_skip_matching_txn(
+        txn, candidate_keys=keys, catalog_fp=catalog, cache=cache
+    )
