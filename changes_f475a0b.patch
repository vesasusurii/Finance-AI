@@ -0,0 +1,16 @@
+"""Stable hashes for bank transfer comment text (LLM cache keys)."""
+
+from __future__ import annotations
+
+import hashlib
+
+
+def normalize_bank_comment(comment: str | None) -> str:
+    if comment is None:
+        return ""
+    return str(comment).strip()
+
+
+def bank_comment_hash(comment: str | None) -> str:
+    normalized = normalize_bank_comment(comment)
+    return hashlib.sha256(normalized.encode("utf-8")).hexdigest()
