+++ b/backend/tests/test_matching_cache.py
@@ -0,0 +1,85 @@
+from datetime import date
+from decimal import Decimal
+
+from services.matching_cache import MatchingInvoiceRow, build_matching_cache
+
+
+def _row(
+    row_id: int,
+    normalized: str,
+    *,
+    paid: date | None = None,
+    amount: Decimal | None = Decimal("10"),
+    inv_date: date | None = date(2026, 1, 15),
+) -> MatchingInvoiceRow:
+    return MatchingInvoiceRow(
+        id=row_id,
+        invoice_number=normalized,
+        invoice_number_normalized=normalized,
+        paid_at_date=paid,
+        match_status="unmatched",
+        name_of_company="Acme",
+        amount=amount,
+        invoice_date=inv_date,
+    )
+
+
+def test_find_by_number_single_and_missing():
+    cache = build_matching_cache(
+        [_row(1, "INV-1")],
+        set(),
+        [],
+    )
+    inv, ambiguous = cache.find_by_number("INV-1")
+    assert inv is not None
+    assert inv.id == 1
+    assert ambiguous is False
+    assert cache.find_by_number("MISSING") == (None, False)
+
+
+def test_find_by_number_ambiguous():
+    cache = build_matching_cache(
+        [_row(1, "DUP"), _row(2, "DUP")],
+        set(),
+        [],
+    )
+    inv, ambiguous = cache.find_by_number("DUP")
+    assert inv is None
+    assert ambiguous is True
+    assert len(cache.list_by_number("DUP")) == 2
+
+
+def test_pair_and_open_task_tracking():
+    cache = build_matching_cache([], {(1, 10)}, [(10, "no_invoice_in_db", "X")])
+    assert cache.pair_exists(1, 10)
+    assert cache.has_open_bank_task(10, "no_invoice_in_db", "X")
+    assert not cache.has_open_bank_task(10, "no_invoice_in_db", "Y")
+    assert cache.has_open_bank_task(10, "internal_error")
+
+    cache.register_open_bank_task(10, "internal_error")
+    assert cache.has_open_bank_task(10, "internal_error")
+
+    cache.register_pair(2, 10)
+    assert cache.pair_exists(2, 10)
+
+
+def test_unpaid_date_window_and_mark_paid():
+    cache = build_matching_cache(
+        [
+            _row(1, "A", paid=None, inv_date=date(2026, 1, 1)),
+            _row(2, "B", paid=date(2026, 1, 1), inv_date=date(2026, 1, 2)),
+        ],
+        set(),
+        [],
+    )
+    assert len(cache.unpaid_for_batch) == 1
+    window = cache.unpaid_in_date_window(
+        invoice_date_from=date(2025, 12, 1),
+        invoice_date_to=date(2026, 1, 15),
+    )
+    assert [r.id for r in window] == [1]
+
+    cache.mark_invoice_paid(1, date(2026, 2, 1))
+    assert cache.get_by_id(1) is not None
+    assert cache.get_by_id(1).paid_at_date == date(2026, 2, 1)
+    assert len(cache.unpaid_for_batch) == 0
