# Borek Finance — copy to .env and fill in (never commit .env)
# See DOCS/12. Deployment & Environments 1.md

# --- Postgres (Compose service: db) ---
POSTGRES_USER=finance
POSTGRES_PASSWORD=change_me_use_strong_password
POSTGRES_DB=finance_ai
POSTGRES_PORT=5432

# Backend database
# Local Compose (default): host must be "db" inside Docker, "localhost" on host
# DATABASE_URL=postgresql+asyncpg://finance:change_me_use_strong_password@db:5432/finance_ai
#
# Supabase (remote): use Session pooler host from dashboard, URL-encode special
# chars in password (? → %3F), append ?ssl=require
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://finance:change_me_use_strong_password@db:5432/finance_ai

# --- Application ---
ENVIRONMENT=local
JWT_SECRET=change_me_min_32_characters_random_string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
LOG_LEVEL=info

# Email verification (optional in local; code is logged if SMTP_HOST is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=vvesasusuri
SMTP_PASSWORD=
SMTP_FROM_EMAIL=vvesasusuri@gmail.com
SMTP_USE_TLS=true

# CORS — browser origin for React (doc 5)
CORS_ORIGINS=http://localhost:5173

# Cookie (local HTTP: false; production HTTPS: true)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Uploads — local volume (STORAGE_BACKEND=local) or Supabase Storage (supabase)
STORAGE_PATH=/data/uploads
STORAGE_BACKEND=local
# Supabase Storage (set STORAGE_BACKEND=supabase to enable)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=invoices

# --- OpenAI (primary OCR — Vision for all invoice uploads, see DOCS/8) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_STRONG=gpt-4o
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
OPENAI_MAX_PDF_PAGES=25
OPENAI_VISION_PAGES_PER_REQUEST=6
OPENAI_VISION_PAGE_BATCH_SIZE=5
OPENAI_MAX_SUPPLEMENTAL_CHARS=80000
OPENAI_PDF_RENDER_SCALE=2.5

# Bank comment extraction — regex first, LLM fallback for ambiguous comments.
BANK_COMMENT_USE_LLM=true
# Batch amount matching when invoice numbers are not in the comment (human approval required).
BATCH_AMOUNT_MATCHING_ENABLED=true
MATCH_AMOUNT_TOLERANCE_EUR=0.02
BATCH_AMOUNT_DATE_WINDOW_DAYS=90

# --- Seed users (scripts/seed_users.py — finance + admin) ---
# SEED_ADMIN_EMAIL=finance@borek.com
# SEED_ADMIN_PASSWORD=changeme

# --- Ports (host machine) ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Frontend ---
# Local Vite dev: leave empty in frontend/.env to use proxy (recommended for auth cookies).
# Direct API: http://localhost:8000
# VITE_API_BASE_URL=
# Show seed email/password on login page (local dev only; set false before prod)
VITE_SHOW_DEV_LOGIN_HINT=true
# Match backend JWT_ACCESS_EXPIRE_MINUTES for proactive refresh timing
VITE_JWT_ACCESS_EXPIRE_MINUTES=15
