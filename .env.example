# Borek Finance — copy to .env and fill in (never commit .env)
# See DOCS/12. Deployment & Environments 1.md

# --- Postgres (Compose service: db) ---
POSTGRES_USER=finance
POSTGRES_PASSWORD=change_me_use_strong_password
POSTGRES_DB=finance_ai
POSTGRES_PORT=5432

# Backend database
# Local Compose (default): host must be "db" inside Docker, "localhost" on host
# DATABASE_URL=postgresql+asyncpg://finance:change_me_use_strong_password@db:5432/finance_ai
#
# Supabase (remote): prefer Transaction pooler (port 6543) for backend + worker.
# Session pooler (5432) caps concurrent clients (~15) and causes 500 errors under load.
# URL-encode special chars in password (? → %3F), append ?ssl=require
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://finance:change_me_use_strong_password@db:5432/finance_ai

# --- Application ---
ENVIRONMENT=local
JWT_SECRET=change_me_min_32_characters_random_string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
LOG_LEVEL=info

# Transactional email (password reset; optional in local)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=vvesasusuri
SMTP_PASSWORD=
SMTP_FROM_EMAIL=vvesasusuri@gmail.com
SMTP_USE_TLS=true

# CORS — browser origin for React (doc 5)
CORS_ORIGINS=http://localhost:5173

# Cookie (local HTTP: false; production HTTPS: true)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Uploads — local volume (STORAGE_BACKEND=local) or Supabase Storage (supabase)
STORAGE_PATH=/data/uploads
STORAGE_BACKEND=local
# Supabase Storage (set STORAGE_BACKEND=supabase to enable)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=invoices

# --- OpenAI (primary OCR — Vision for all invoice uploads, see DOCS/8) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_STRONG=gpt-4o
OPENAI_ADAPTIVE_MODEL_ROUTING=true
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
# GPT-5/o-series use internal reasoning tokens before JSON output — needs a much higher budget than gpt-4o-mini
OPENAI_REASONING_MAX_COMPLETION_TOKENS=16000
# Strong-model retry adds a full second pass (gpt-4o) — disable for lower latency.
OPENAI_STRONG_RETRY_ENABLED=false
# Digital PDF fast path: parse text layer before Vision (see OPENAI_TEXT_FIRST_* below).
OPENAI_TEXT_FIRST_ENABLED=true
OPENAI_TEXT_FIRST_MAX_PAGES=10
OPENAI_TEXT_FIRST_MIN_CHARS=200
OPENAI_HYBRID_TEXT_ENABLED=true
# Field recovery triggers an extra OpenAI call when required fields are missing.
OPENAI_FIELD_RECOVERY_ENABLED=false
OPENAI_TARGETED_FIELD_RECOVERY_ENABLED=true
OPENAI_TARGETED_FIELD_RECOVERY_MAX_FIELDS=2
OPENAI_TARGETED_FIELD_RECOVERY_MIN_CONFIDENCE=0.65
EXTRACTION_EVAL_BASELINE_ACCURACY=1.0
OPENAI_MAX_PDF_PAGES=25
OPENAI_VISION_PAGES_PER_REQUEST=8
OPENAI_VISION_PAGE_BATCH_SIZE=6
OPENAI_PAGE_BATCH_CONCURRENCY=4
OPENAI_MAX_SUPPLEMENTAL_CHARS=80000
OPENAI_VISION_SUPPLEMENTAL_TEXT_MAX_CHARS=12000
OPENAI_PDF_RENDER_SCALE=1.5
OPENAI_ADAPTIVE_RENDER_SCALE=true
OPENAI_RENDER_SCALE_HIGH=1.5
OPENAI_RENDER_SCALE_MEDIUM=1.25
OPENAI_RENDER_SCALE_LOW=1.0
OPENAI_PARALLEL_PDF_RENDERING=true
OPENAI_PDF_RENDER_WORKERS=4
OPENAI_VISION_FULL_DOCUMENT_MAX_BYTES=2500000
# Multi-page Vision: high detail on first/last pages only; middle pages use low/auto.
OPENAI_ADAPTIVE_IMAGE_DETAIL=true
OPENAI_ADAPTIVE_IMAGE_DETAIL_MIDDLE=low
# Dynamic Vision page selection: score pages and cap Vision calls on long PDFs.
OPENAI_DYNAMIC_PAGE_SELECTION_ENABLED=true
OPENAI_DYNAMIC_PAGE_SELECTION_MAX_PAGES=4
OPENAI_PRECLASSIFICATION_ROUTING_ENABLED=true
# Queue prioritisation: small/fast jobs ahead of large scans; starvation boost after wait.
OPENAI_QUEUE_PRIORITIZATION_ENABLED=true
OPENAI_QUEUE_STARVATION_BOOST_SECONDS=60
# Pipeline overlap: run independent stages concurrently (render/vision/persist prep).
OPENAI_PIPELINE_OVERLAP_ENABLED=true
# OCR SLO thresholds for production monitoring (milliseconds unless noted).
OCR_SLO_TOTAL_MS=8000
OCR_SLO_OPENAI_MS=6000
OCR_SLO_QUEUE_WAIT_MS=5000
OCR_SLO_MAX_OPENAI_CALLS=3
OCR_SLO_MAX_FALLBACK_RATE=0.3
# Multi-page Vision: merge partial page results in Python before LLM merge call.
OPENAI_DETERMINISTIC_MERGE_ENABLED=true
OPENAI_DETERMINISTIC_MERGE_MIN_CONFIDENCE=0.7
# Adaptive queue rate limits — raise if your OpenAI tier allows more throughput.
OPENAI_RPS_LIMIT=5
OPENAI_CONCURRENCY_LIMIT=4
OCR_CACHE_ENABLED=true
MAX_STARTUP_RECOVERY_JOBS=50

# Bank comment extraction — regex first, LLM fallback for ambiguous comments.
BANK_COMMENT_USE_LLM=false
# Batch amount matching when invoice numbers are not in the comment (human approval required).
BATCH_AMOUNT_MATCHING_ENABLED=true
MATCH_AMOUNT_TOLERANCE_EUR=0.02
BATCH_AMOUNT_DATE_WINDOW_DAYS=90

# --- Supabase Postgres pool tuning ---
# Ignored when DATABASE_URL uses Supabase pooler (SQLAlchemy uses NullPool there).
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800
SLOW_ROUTE_MS=1500

# Bank comment extraction — regex first, LLM fallback for ambiguous comments.
BANK_COMMENT_USE_LLM=true
# Batch amount matching when invoice numbers are not in the comment (human approval required).
BATCH_AMOUNT_MATCHING_ENABLED=true
MATCH_AMOUNT_TOLERANCE_EUR=0.02
BATCH_AMOUNT_DATE_WINDOW_DAYS=90

# Bank comment extraction — regex first, LLM fallback for ambiguous comments.
BANK_COMMENT_USE_LLM=true
# Batch amount matching when invoice numbers are not in the comment (human approval required).
BATCH_AMOUNT_MATCHING_ENABLED=true
MATCH_AMOUNT_TOLERANCE_EUR=0.02
BATCH_AMOUNT_DATE_WINDOW_DAYS=90

# --- Redis (RQ job queues — required when using docker compose backend/worker) ---
# Compose sets REDIS_URL=redis://redis:6379/0 for backend/worker containers.
# Host-only dev against local Redis: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379
# adaptive = ocr_high_priority, ocr_normal, review, transaction queues; strict = single RQ queue
# inline = OCR in API process (no separate worker; dev/small deployments only)
QUEUE_MODE=adaptive
# Optional override for backend/run_worker.sh (space-separated RQ queue names)
# WORKER_QUEUES=finance-ai ocr_high_priority ocr_normal review transaction

# --- Ports (host machine) ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Frontend ---
# Local Vite dev: leave empty in frontend/.env to use proxy (recommended for auth cookies).
# Direct API: http://localhost:8000
# VITE_API_BASE_URL=
# Match backend JWT_ACCESS_EXPIRE_MINUTES for proactive refresh timing
VITE_JWT_ACCESS_EXPIRE_MINUTES=15
# Password reset links in emails (local dev default)
APP_BASE_URL=http://localhost:5173

# --- OCR accuracy vs latency (optional overrides) ---
# OPENAI_STRONG_RETRY_ENABLED=true
# OPENAI_FIELD_RECOVERY_ENABLED=true
# OPENAI_PDF_RENDER_SCALE=2.0
