# Borek Finance — copy to .env and fill in (never commit .env)
# See DOCS/12. Deployment & Environments 1.md

# --- Postgres (Compose service: db) ---
POSTGRES_USER=finance
POSTGRES_PASSWORD=change_me_use_strong_password
POSTGRES_DB=finance_ai
POSTGRES_PORT=5432

# Backend (inside Docker use host "db")
DATABASE_URL=postgresql+asyncpg://finance:change_me_use_strong_password@db:5432/finance_ai

# --- Application ---
ENVIRONMENT=local
JWT_SECRET=change_me_min_32_characters_random_string
JWT_EXPIRE_MINUTES=480
LOG_LEVEL=info

# CORS — browser origin for React (doc 5)
CORS_ORIGINS=http://localhost:5173

# Cookie (local HTTP: false; production HTTPS: true)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Uploads — mounted volume in Compose
STORAGE_PATH=/data/uploads

# --- OpenAI (primary OCR — Vision for all invoice uploads, see DOCS/8) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_STRONG=gpt-4o
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
OPENAI_MAX_PDF_PAGES=25
OPENAI_VISION_PAGES_PER_REQUEST=6
OPENAI_VISION_PAGE_BATCH_SIZE=5
OPENAI_MAX_SUPPLEMENTAL_CHARS=80000
OPENAI_PDF_RENDER_SCALE=2.5

# --- Seed admin (optional overrides for scripts/seed_admin.py) ---
# SEED_ADMIN_EMAIL=finance@borek.com
# SEED_ADMIN_PASSWORD=changeme

# --- Ports (host machine) ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Frontend ---
# Local Vite dev: leave empty in frontend/.env to use proxy (recommended for auth cookies).
# Direct API: http://localhost:8000
# VITE_API_BASE_URL=
# Show seed email/password on login page (local dev only; set false before prod)
VITE_SHOW_DEV_LOGIN_HINT=true
